DATABASE_URL="file:./dev.db"
# Required on Vercel. Create a Turso database and apply the SQLite migrations.
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-database-token"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Use your exact Vercel production/custom domain in production.
NEXTAUTH_URL="http://localhost:3000"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Google login and Drive OAuth
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:3000/api/google-drive/callback"
GOOGLE_DRIVE_FOLDER="EdgeLedger Content"
GOOGLE_ADMIN_EMAILS="owner@gmail.com"
# Optional recovery path for an existing Drive authorization. Keep this server-only and secret.
GOOGLE_DRIVE_REFRESH_TOKEN=""
GOOGLE_DRIVE_ACCOUNT_EMAIL="owner@gmail.com"
GOOGLE_DRIVE_ACCOUNT_NAME="Owner"
# Only these main-owner emails can grant or revoke full administrator access.
# When omitted, the first GOOGLE_ADMIN_EMAILS entry is used as the owner.
PLATFORM_OWNER_EMAILS="owner@gmail.com"

# Firebase Storage
# Local-only alternative. Do not use a filesystem credential path on Vercel.
FIREBASE_SERVICE_ACCOUNT_PATH="C:\\path\\to\\firebase-service-account.json"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@example-project.iam.gserviceaccount.com"
# Preserve the escaped newlines when entering this value in Vercel.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.firebaseio.com"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
FIREBASE_STORAGE_FOLDER="EdgeLedger Content"
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-web-or-android-api-key"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.firebaseio.com"
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"
MAX_UPLOAD_MB="20480"
